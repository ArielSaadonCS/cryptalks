DATABASE_URL=postgresql://cryptalks:cryptalks@localhost:5432/cryptalks
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional. The app works without it using CoinGecko's free public endpoint.
COINGECKO_API_KEY=

# Optional. Without it, the dashboard uses static fallback news.
CRYPTOPANIC_API_KEY=

# Optional. Without both a key and a model, the AI Insight of the Day uses a
# deterministic fallback. Pick any model ID from https://openrouter.ai/models
# (including free-tier models) and put it in OPENROUTER_MODEL.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
